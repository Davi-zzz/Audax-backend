generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String  @id
  sku         String  @unique
  name        String
  description String  @default("")
  price       Int
  stock       Int
  image       Bytes?

  @@map("products")
}
