# Repository Mode: 'in-memory' or 'prisma'
# - in-memory: fast, no database needed (development/testing)
# - prisma: PostgreSQL integration (production/integration tests)
REPOSITORY_TYPE=in-memory

# Database URL (only needed if REPOSITORY_TYPE=prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_tech_db

# Server
PORT=3000
